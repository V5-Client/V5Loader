{
    "schemaVersion": 1,
    "id": "ctjs",
    "name": "V5",
    "version": "$version",
    "description": "A ChatTriggers fork optimized for advanced automation and high-performance client-side scripting.",
    "authors": ["Zurviq, rdbt, EpsilonPhoenix"],
    "contributors": ["Oblongboot", "Nathan", "IcyHenryT"],
    "icon": "assets/v5/icon.png",
    "license": ["All rights reserved."],
    "contact": {
        "homepage": "https://rdbt.top/",
        "sources": "https://discord.gg/RvQJq7vE3a",
        "issues": "https://discord.gg/RvQJq7vE3a"
    },
    "environment": "client",
    "entrypoints": {
        "preLaunch": [
            "com.chattriggers.ctjs.internal.launch.CTJSPreLaunch"
        ],
        "client": [
            "com.chattriggers.ctjs.CTJS",
            "com.v5.swift.Swift",
            "com.v5.Entrypoint"
        ],
        "modmenu": [
            "com.chattriggers.ctjs.internal.compat.ModMenuEntry"
        ]
    },
    "mixins": ["ctjs.mixins.json", "v5.mixins.json"],
    "depends": {
        "fabricloader": ">=$loader_version",
        "fabric-api": ">=$fabric_api_version",
        "fabric-language-kotlin": ">=$fabric_kotlin_version"
    },
    "breaks": {
        "smoothboot": "*",
        "ctjs": "*",
        "stfu": "*",
        "nvidium": "*"
    },
    "custom": {
        "ctjs:yarn-mappings": "$yarn_mappings",
        "modmenu": {
            "links": {
                "modmenu.discord": "https://discord.gg/chattriggers"
            }
        }
    },
    "accessWidener": "ctjs.accesswidener"
}
